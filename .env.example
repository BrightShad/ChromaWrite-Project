# ── Groq API (free, no credit card) ───────────────────────────────────────────
# console.groq.com → API Keys → Create API Key
VITE_GROQ_API_KEY=gsk_your_key_here

# ── Supabase (free database + auth) ───────────────────────────────────────────
# supabase.com → project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Google AI — image generation ──────────────────────────────────────────────
# aistudio.google.com → Get API Key (free tier available)
VITE_GOOGLE_AI_KEY=your-google-ai-key-here
